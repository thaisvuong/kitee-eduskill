# Sao chép thành .env.local và sửa cho máy bạn
# Thư mục làm việc Kitee
KITEE_WORKSPACE_DIR=/Users/you/Kitee
# Nơi lưu file kết quả (.docx/.pdf)
HERMES_EDUSKILL_OUTPUT_DIR=/Users/you/Kitee/Output
# Thư mục engine eduSkill (chứa slash.mjs)
EDUSKILL_DIR=/Users/you/eduSkill
# Hồ sơ Hermes (OAuth, settings JSON)
HERMES_HOME=/Users/you/.hermes/profiles/cmkitee
# Google Drive folder id (tùy chọn)
HERMES_DRIVE_PARENT_ID=your_drive_folder_id
# LLM router (OpenAI-compatible)
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
# Model mặc định
HERMES_WORKER_MODEL=gc/gemini-2.5-flash
# Chuỗi fallback khi model/quota lỗi (comma-separated)
HERMES_FALLBACK_MODELS=gc/gemini-2.5-flash,gc/gemini-2.5-pro,gc/gemini-3.1-flash-lite-preview,cx/gpt-5.5,cx/gpt-5.4,cc/claude-opus-4-8,openrouter/openrouter/free
# Retry mỗi model trước khi nhảy model khác
HERMES_MODEL_RETRIES=2
HERMES_MODEL_RETRY_DELAY_MS=1200
