{
 "name": "kientreaaa",
 "version": "0.1.0",
 "private": true,
 "type": "module",
 "scripts": {
  "dev": "next dev -p 3100",
  "build": "next build && mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static && cp -R .next/static .next/standalone/.next/static",
  "start": "KIENTRE_APP_ROOT=${KIENTRE_APP_ROOT:-$PWD} KIENTRE_ENGINE_DIR=${KIENTRE_ENGINE_DIR:-$PWD/kientre-engine} PORT=${PORT:-3100} node .next/standalone/server.js",
  "setup": "npm install && npm run build",
  "typecheck": "tsc --noEmit"
 },
 "dependencies": {
  "lucide-react": "^0.468.0",
  "mammoth": "^1.12.0",
  "next": "^14.2.35",
  "react": "18.3.1",
  "react-dom": "18.3.1"
 },
 "devDependencies": {
  "@types/node": "^22.10.2",
  "@types/react": "^18.3.18",
  "@types/react-dom": "^18.3.5",
  "typescript": "^5.7.2"
 }
}
