{
  "openapi": "3.1.0",
  "info": {
    "title": "KientreAAA Web App API",
    "version": "0.1.0",
    "description": "OpenAPI spec for KientreAAA local-first Next.js web app. Covers module execution, agent runs, NotebookLM, local files, Drive helpers, settings, masked Google OAuth, and update endpoints. SSE endpoints are documented with text/event-stream responses. Secrets are never returned raw; examples use placeholders only."
  },
  "servers": [
    {
      "url": "http://localhost:3100",
      "description": "Default local production port"
    }
  ],
  "tags": [
    { "name": "health" },
    { "name": "settings" },
    { "name": "models" },
    { "name": "google-auth" },
    { "name": "drive" },
    { "name": "files" },
    { "name": "sources" },
    { "name": "skills" },
    { "name": "sessions" },
    { "name": "memory" },
    { "name": "notebooklm" },
    { "name": "chat" },
    { "name": "run" },
    { "name": "agent" },
    { "name": "update" },
    { "name": "app-info" }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health and resolved runtime config",
        "responses": {
          "200": {
            "description": "Health payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "app": { "type": "string" },
                    "config": { "$ref": "#/components/schemas/KientreConfig" }
                  },
                  "required": ["ok", "app", "config"]
                }
              }
            }
          }
        }
      }
    },
    "/api/kientre-info": {
      "get": {
        "tags": ["app-info"],
        "summary": "Resolved app/workspace info",
        "parameters": [
          {
            "name": "moduleKey",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Optional module key to resolve module-specific defaults"
          }
        ],
        "responses": {
          "200": {
            "description": "App info payload"
          }
        }
      }
    },
    "/api/models": {
      "get": {
        "tags": ["models"],
        "summary": "List available models from local router plus direct providers",
        "parameters": [
          {
            "name": "router",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Override router base URL, e.g. http://localhost:20128/v1"
          }
        ],
        "responses": {
          "200": {
            "description": "Model catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "models": { "type": "array", "items": { "type": "string" } },
                    "direct": { "type": "array", "items": { "type": "string" } },
                    "router": { "type": "string" },
                    "routerError": { "type": "string" }
                  },
                  "required": ["ok", "models", "direct", "router"]
                }
              }
            }
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "tags": ["settings"],
        "summary": "Read masked app settings and module configuration",
        "responses": {
          "200": {
            "description": "Masked settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "settings": { "$ref": "#/components/schemas/SettingsResponse" },
                    "modules": {
                      "type": "object",
                      "additionalProperties": { "$ref": "#/components/schemas/ModuleMeta" }
                    },
                    "path": { "type": "string" }
                  },
                  "required": ["ok", "settings", "modules", "path"]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["settings"],
        "summary": "Update persisted settings (write-only for API keys)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SettingsUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated masked settings"
          }
        }
      }
    },
    "/api/google-auth": {
      "get": {
        "tags": ["google-auth"],
        "summary": "Read masked Google OAuth/token status",
        "responses": {
          "200": {
            "description": "Masked credential status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GoogleAuthStatus" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["google-auth"],
        "summary": "Upload OAuth JSON, create consent URL, exchange auth code, or verify Drive access",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "token": {
                        "description": "OAuth client JSON or token JSON. Raw secrets are accepted only in POST and never returned back.",
                        "oneOf": [
                          { "type": "string" },
                          { "type": "object", "additionalProperties": true }
                        ]
                      }
                    },
                    "required": ["token"]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "action": { "type": "string", "enum": ["auth-url"] }
                    },
                    "required": ["action"]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "action": { "type": "string", "enum": ["auth-code"] },
                      "code": { "type": "string" },
                      "url": { "type": "string" }
                    },
                    "required": ["action"]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "action": { "type": "string", "enum": ["verify"] }
                    },
                    "required": ["action"]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Success response for upload/auth-url/auth-code/verify" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      }
    },
    "/api/drive-folder": {
      "get": {
        "tags": ["drive"],
        "summary": "Resolve Drive folder metadata from folder ID",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Folder metadata or validation result" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      }
    },
    "/api/files": {
      "get": {
        "tags": ["files"],
        "summary": "List visible files in workspace/output areas",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "File listing" }
        }
      },
      "delete": {
        "tags": ["files"],
        "summary": "Delete a file or directory entry by path",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Delete result" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      }
    },
    "/api/file": {
      "get": {
        "tags": ["files"],
        "summary": "Read one file",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "File content payload" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      },
      "put": {
        "tags": ["files"],
        "summary": "Write one file",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["path", "content"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Write result" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      }
    },
    "/api/upload": {
      "post": {
        "tags": ["files"],
        "summary": "Upload one or more local files to workspace upload area",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Uploaded file metadata" },
          "400": { "$ref": "#/components/responses/Error400" }
        }
      }
    },
    "/api/sources": {
      "get": {
        "tags": ["sources"],
        "summary": "List saved sources",
        "responses": { "200": { "description": "Sources store" } }
      },
      "post": {
        "tags": ["sources"],
        "summary": "Create or update a saved source",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SourceItem" }
            }
          }
        },
        "responses": { "200": { "description": "Upsert result" } }
      },
      "delete": {
        "tags": ["sources"],
        "summary": "Delete a source by id",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Delete result" } }
      }
    },
    "/api/skills": {
      "get": {
        "tags": ["skills"],
        "summary": "List user-defined module skills",
        "responses": { "200": { "description": "Skill store" } }
      },
      "post": {
        "tags": ["skills"],
        "summary": "Create or update a skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SkillItem" }
            }
          }
        },
        "responses": { "200": { "description": "Upsert result" } }
      },
      "delete": {
        "tags": ["skills"],
        "summary": "Delete a skill by id",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Delete result" } }
      }
    },
    "/api/sessions": {
      "get": {
        "tags": ["sessions"],
        "summary": "List saved module sessions",
        "parameters": [
          { "name": "moduleKey", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Session list" } }
      },
      "post": {
        "tags": ["sessions"],
        "summary": "Create or update a session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SessionItem" }
            }
          }
        },
        "responses": { "200": { "description": "Upsert result" } }
      },
      "delete": {
        "tags": ["sessions"],
        "summary": "Delete a session by id",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Delete result" } }
      }
    },
    "/api/session-memory": {
      "get": {
        "tags": ["memory"],
        "summary": "Get persisted memory for one session",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Session memory payload" } }
      }
    },
    "/api/memory-chat": {
      "post": {
        "tags": ["memory"],
        "summary": "Handle status/progress/memory chat outside hard module flow",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "type": "string" },
                  "sessionId": { "type": "string" },
                  "moduleKey": { "type": "string" },
                  "runningJobs": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true }
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Assistant chat response" } }
      }
    },
    "/api/notebooklm": {
      "get": {
        "tags": ["notebooklm"],
        "summary": "List notebooks or retrieve NotebookLM workspace state",
        "parameters": [
          { "name": "action", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "NotebookLM GET response" } }
      },
      "post": {
        "tags": ["notebooklm"],
        "summary": "Operate NotebookLM bridge (generate/list/select/etc.)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": { "type": "string" },
                  "moduleKey": { "type": "string" },
                  "notebookIds": { "type": "array", "items": { "type": "string" } },
                  "prompt": { "type": "string" },
                  "artifactType": { "type": "string" }
                },
                "required": ["action"]
              }
            }
          }
        },
        "responses": { "200": { "description": "NotebookLM action result" } }
      }
    },
    "/api/chat": {
      "post": {
        "tags": ["chat"],
        "summary": "Legacy module chat endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "type": "string" },
                  "settings": { "type": "object", "additionalProperties": true }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Chat result" } }
      }
    },
    "/api/run": {
      "post": {
        "tags": ["run"],
        "summary": "Run hard pipeline job and stream progress over SSE",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "jobId": { "type": "string" },
                  "command": { "type": "string" },
                  "settings": { "type": "object", "additionalProperties": true }
                },
                "required": ["command"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Server-Sent Events stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "example": "event: log\ndata: {\"line\":\"☁️ Đang tải 1 file .docx lên Google Drive + chuyển Google Docs...\"}\n\n"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["run"],
        "summary": "Cancel a running hard pipeline job",
        "parameters": [
          { "name": "jobId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Cancel result" } }
      }
    },
    "/api/agent": {
      "post": {
        "tags": ["agent"],
        "summary": "Run agent-mode module and stream steps over SSE",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "jobId": { "type": "string" },
                  "task": { "type": "string" },
                  "moduleKey": { "type": "string", "default": "topic" },
                  "history": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string" },
                        "content": { "type": "string" }
                      }
                    }
                  },
                  "settings": { "type": "object", "additionalProperties": true },
                  "sessionId": { "type": "string" }
                },
                "required": ["task"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Server-Sent Events stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "example": "event: agent_step\ndata: {\"type\":\"assistant\",\"text\":\"Intent: chạy flow — yêu cầu tạo/xử lý tài liệu\"}\n\n"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["agent"],
        "summary": "Cancel a running agent job",
        "parameters": [
          { "name": "jobId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Cancel result" } }
      }
    },
    "/api/update": {
      "get": {
        "tags": ["update"],
        "summary": "Read current update status",
        "responses": { "200": { "description": "Update status" } }
      },
      "post": {
        "tags": ["update"],
        "summary": "Run local self-update routine",
        "responses": { "200": { "description": "Update execution result" } }
      }
    }
  },
  "components": {
    "responses": {
      "Error400": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ok": { "type": "boolean" },
                "error": { "type": "string" }
              },
              "required": ["ok", "error"]
            }
          }
        }
      }
    },
    "schemas": {
      "KientreConfig": {
        "type": "object",
        "properties": {
          "workspaceDir": { "type": "string" },
          "outputDir": { "type": "string" },
          "engineDir": { "type": "string" },
          "hermesHome": { "type": "string" },
          "driveParentId": { "type": "string" },
          "googleCredentialFile": { "type": "string" },
          "routerBaseUrl": { "type": "string" },
          "defaultWorkerModel": { "type": "string" },
          "defaultSummary": { "type": "boolean" },
          "fallbackModels": { "type": "string" },
          "modelRetries": { "type": "integer" },
          "retryDelayMs": { "type": "integer" }
        }
      },
      "MaskedKey": {
        "type": "object",
        "properties": {
          "present": { "type": "boolean" },
          "hint": { "type": "string" }
        },
        "required": ["present", "hint"]
      },
      "ModuleMeta": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "command": { "type": "string" },
          "needsFile": { "type": "boolean" }
        },
        "required": ["label", "command", "needsFile"]
      },
      "AgentModels": {
        "type": "object",
        "properties": {
          "intent": { "type": "string" },
          "architect": { "type": "string" },
          "examiner": { "type": "string" },
          "solver": { "type": "string" },
          "judge": { "type": "string" },
          "student": { "type": "string" },
          "reviewer": { "type": "string" },
          "visualcurator": { "type": "string" },
          "artist": { "type": "string" },
          "quizplanner": { "type": "string" }
        },
        "additionalProperties": { "type": "string" }
      },
      "ModuleSettings": {
        "type": "object",
        "properties": {
          "subject": { "type": "string" },
          "grade": { "type": "string" },
          "model": { "type": "string" },
          "driveFolderId": { "type": "string" },
          "driveFolderUrl": { "type": "string" },
          "driveFolderName": { "type": "string" },
          "useSummary": { "type": "boolean" },
          "uploadDrive": { "type": "boolean" },
          "mode": { "type": "string" },
          "notebookIds": { "type": "array", "items": { "type": "string" } },
          "activeNotebookId": { "type": "string" },
          "selectedNotebookIds": { "type": "array", "items": { "type": "string" } },
          "notebookPrompt": { "type": "string" },
          "agentMode": { "type": "boolean" },
          "persona": { "type": "string" },
          "systemPrompt": { "type": "string" },
          "skillIds": { "type": "array", "items": { "type": "string" } },
          "enabledTools": { "type": "array", "items": { "type": "string" } },
          "maxTurns": { "type": "integer" },
          "useSources": { "type": "boolean" },
          "questionTypes": { "type": "array", "items": { "type": "string" } },
          "access": { "type": "string" },
          "definition": { "type": "string" },
          "icon": { "type": "string" },
          "color": { "type": "string" },
          "customAgents": { "type": "array", "items": { "type": "string" } },
          "agentModels": { "$ref": "#/components/schemas/AgentModels" },
          "quizCount": { "type": "integer" },
          "quizTotalScore": { "type": "integer" },
          "quizTimeMinutes": { "type": "integer" },
          "customSubjects": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      },
      "SettingsResponse": {
        "type": "object",
        "properties": {
          "outputDir": { "type": "string" },
          "workspaceDir": { "type": "string" },
          "engineDir": { "type": "string" },
          "hermesHome": { "type": "string" },
          "googleCredentialFile": { "type": "string" },
          "routerBaseUrl": { "type": "string" },
          "fallbackModels": { "type": "string" },
          "modelRetries": { "type": "integer" },
          "retryDelayMs": { "type": "integer" },
          "apiKeys": {
            "type": "object",
            "properties": {
              "gemini": { "$ref": "#/components/schemas/MaskedKey" },
              "deepseek": { "$ref": "#/components/schemas/MaskedKey" },
              "glm": { "$ref": "#/components/schemas/MaskedKey" },
              "openrouter": { "$ref": "#/components/schemas/MaskedKey" }
            },
            "required": ["gemini", "deepseek", "glm", "openrouter"]
          },
          "modules": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/ModuleSettings" }
          }
        },
        "required": ["outputDir", "workspaceDir", "engineDir", "hermesHome", "googleCredentialFile", "routerBaseUrl", "fallbackModels", "modelRetries", "retryDelayMs", "apiKeys", "modules"]
      },
      "SettingsUpdate": {
        "type": "object",
        "properties": {
          "outputDir": { "type": "string" },
          "workspaceDir": { "type": "string" },
          "engineDir": { "type": "string" },
          "hermesHome": { "type": "string" },
          "googleCredentialFile": { "type": "string" },
          "routerBaseUrl": { "type": "string" },
          "fallbackModels": { "type": "string" },
          "modelRetries": { "type": "integer" },
          "retryDelayMs": { "type": "integer" },
          "apiKeys": {
            "type": "object",
            "properties": {
              "gemini": { "type": "string", "description": "Write-only API key or empty string to clear" },
              "deepseek": { "type": "string", "description": "Write-only API key or empty string to clear" },
              "glm": { "type": "string", "description": "Write-only API key or empty string to clear" },
              "openrouter": { "type": "string", "description": "Write-only API key or empty string to clear" }
            },
            "additionalProperties": true
          },
          "modules": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/ModuleSettings" }
          }
        },
        "additionalProperties": false
      },
      "GoogleAuthStatus": {
        "type": "object",
        "properties": {
